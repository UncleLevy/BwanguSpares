{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "buyer_email": {
      "type": "string"
    },
    "buyer_name": {
      "type": "string"
    },
    "shop_id": {
      "type": "string"
    },
    "shop_name": {
      "type": "string"
    },
    "shop_owner_email": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_date": {
      "type": "string"
    },
    "buyer_unread": {
      "type": "number",
      "default": 0
    },
    "shop_unread": {
      "type": "number",
      "default": 0
    },
    "archived_by_buyer": {
      "type": "boolean",
      "default": false
    },
    "archived_by_shop": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "required": [
    "buyer_email",
    "shop_id"
  ],
  "rls": {
    "read": {
      "formula": "record.buyer_email == user.email || record.shop_owner_email == user.email || user.role == 'admin'"
    },
    "select": {
      "formula": "record.buyer_email == user.email || record.shop_owner_email == user.email || user.role == 'admin'"
    },
    "insert": {
      "formula": "request.buyer_email == user.email || user.role == 'shop_owner'"
    },
    "update": {
      "formula": "record.buyer_email == user.email || record.shop_owner_email == user.email || user.role == 'admin'"
    },
    "delete": {
      "formula": "user.role == 'admin'"
    },
    "create": {
      "created_by": "{{user.email}}"
    },
    "write": {
      "formula": "record.buyer_email == user.email || record.shop_owner_email == user.email || user.role == 'admin'"
    }
  }
}