{
  "name": "Appointment",
  "type": "object",
  "properties": {
    "technician_id": {
      "type": "string"
    },
    "technician_name": {
      "type": "string"
    },
    "shop_id": {
      "type": "string"
    },
    "shop_name": {
      "type": "string"
    },
    "shop_owner_email": {
      "type": "string"
    },
    "buyer_email": {
      "type": "string"
    },
    "buyer_name": {
      "type": "string"
    },
    "buyer_phone": {
      "type": "string"
    },
    "problem_type": {
      "type": "string",
      "enum": [
        "engine",
        "electrical",
        "body_work",
        "transmission",
        "brakes",
        "diagnostics",
        "ac_heating",
        "tyres",
        "general"
      ]
    },
    "description": {
      "type": "string"
    },
    "appointment_date": {
      "type": "string",
      "format": "date"
    },
    "time_slot": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "completed",
        "cancelled"
      ],
      "default": "pending"
    },
    "hire_request_id": {
      "type": "string"
    },
    "shop_notes": {
      "type": "string"
    }
  },
  "required": [
    "technician_id",
    "shop_id",
    "buyer_email",
    "appointment_date",
    "time_slot"
  ],
  "rls": {
    "select": {
      "formula": "record.buyer_email == user.email || record.shop_owner_email == user.email || user.role == 'admin'"
    },
    "insert": {
      "formula": "request.buyer_email == user.email || user.role == 'shop_owner'"
    },
    "update": {
      "formula": "record.buyer_email == user.email || record.shop_owner_email == user.email || user.role == 'admin'"
    },
    "delete": {
      "formula": "user.role == 'admin'"
    },
    "create": {
      "created_by": "{{user.email}}"
    },
    "write": {
      "formula": "record.buyer_email == user.email || record.shop_owner_email == user.email || user.role == 'admin'"
    }
  }
}