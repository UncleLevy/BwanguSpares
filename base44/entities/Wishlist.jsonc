{
  "name": "Wishlist",
  "type": "object",
  "properties": {
    "buyer_email": {
      "type": "string"
    },
    "product_id": {
      "type": "string"
    },
    "product_name": {
      "type": "string"
    },
    "shop_id": {
      "type": "string"
    },
    "shop_name": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "image_url": {
      "type": "string"
    },
    "category": {
      "type": "string"
    }
  },
  "required": [
    "buyer_email",
    "product_id",
    "shop_id",
    "price"
  ],
  "rls": {
    "read": {
      "formula": "record.buyer_email == user.email || user.role == 'admin'"
    },
    "select": {
      "formula": "record.buyer_email == user.email || user.role == 'admin'"
    },
    "insert": {
      "formula": "request.buyer_email == user.email"
    },
    "update": {
      "formula": "record.buyer_email == user.email"
    },
    "delete": {
      "formula": "record.buyer_email == user.email || user.role == 'admin'"
    },
    "create": {
      "created_by": "{{user.email}}"
    },
    "write": {
      "formula": "record.buyer_email == user.email || user.role == 'admin'"
    }
  }
}